{
    "name": "bar-lobby",
    "version": "0.14.0",
    "private": true,
    "description": "Lobby client for the RTS game Beyond All Reason",
    "author": "Jazcash <jaspercashmore@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/beyond-all-reason/bar-lobby.git"
    },
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite",
        "debug": "electron-vite --remote-debugging-port=9223",
        "build": "electron-vite build",
        "release": "electron-builder --config .electron-builder.config.js",
        "local-build": "npm run build && npm run compile",
        "fix": "npm run type-check && npm run tidy",
        "check": "npm run type-check && npm run tidy-check",
        "type-check": "vue-tsc --noEmit -p tsconfig.node.json && vue-tsc --noEmit -p tsconfig.web.json",
        "tidy": "npm run lint && npm run format",
        "tidy-check": "npm run lint-check && npm run format-check",
        "lint": "eslint . --ext .ts,.vue --fix",
        "lint-check": "eslint . --ext .ts,.vue",
        "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
        "format-check": "prettier --check \"src/**/*.{ts,vue,scss,json}\"",
        "test": "vitest run",
        "postinstall": "electron-builder install-app-deps",
        "postuninstall": "electron-builder install-app-deps",
        "preversion": "npm run check",
        "postversion": "git push && git push --tags"
    },
    "debug": {
        "env": {
            "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344"
        }
    },
    "engines": {
        "node": "^20"
    },
    "build": {
        "electronDist": "node_modules/electron/dist"
    },
    "dependencies": {
        "@iconify-icons/mdi": "^1.2.48",
        "@iconify/json": "^2.2.251",
        "@iconify/vue": "^4.1.2",
        "@types/dompurify": "^3.0.5",
        "@types/marked": "^6.0.0",
        "@vueuse/core": "^11.1.0",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "axios": "^1.7.7",
        "better-sqlite3": "^11.3.0",
        "date-fns": "^4.1.0",
        "dompurify": "^3.1.6",
        "env-paths": "^3.0.0",
        "flag-icons": "^7.2.3",
        "glob-promise": "^6.0.7",
        "howler": "^2.2.4",
        "kysely": "^0.27.4",
        "luaparse": "^0.3.1",
        "marked": "^14.1.2",
        "node-7z": "^3.0.0",
        "node-self": "^1.0.2",
        "octokit": "^4.0.2",
        "pixi.js": "^8.4.1",
        "primeicons": "^7.0.0",
        "primevue": "^4.0.7",
        "sdfz-demo-parser": "^5.11.0",
        "spring-map-parser": "^6.1.1",
        "steamworks.js": "0.4.0",
        "tachyon-client": "^10.4.1",
        "vue-i18n": "^10.0.1",
        "vue3-markdown-it": "^1.0.10",
        "vue3-popper": "^1.5.0"
    },
    "devDependencies": {
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@electron-toolkit/utils": "^3.0.0",
        "@sinclair/typebox": "^0.33.12",
        "@types/electron-devtools-installer": "^2.2.5",
        "@types/howler": "^2.2.11",
        "@types/luaparse": "^0.2.12",
        "@types/node-7z": "^2.1.10",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^8.6.0",
        "@vitejs/plugin-vue": "^5.1.4",
        "@vue/compiler-sfc": "^3.5.7",
        "@vue/devtools": "^7.4.5",
        "bar-db": "^6.4.1",
        "cross-env": "^7.0.3",
        "electron": "^32.1.2",
        "electron-builder": "^25.0.5",
        "electron-devtools-installer": "^3.2.0",
        "electron-updater": "^6.3.4",
        "electron-vite": "^2.3.0",
        "eslint": "^9.11.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-unused-imports": "^4.1.4",
        "playwright": "^1.47.2",
        "prettier": "^3.3.3",
        "rimraf": "^6.0.1",
        "sass": "^1.79.3",
        "tsconfig-paths": "^4.2.0",
        "type-fest": "^4.26.1",
        "typescript": "^5.6.2",
        "unplugin-vue-router": "^0.10.8",
        "uuid": "^10.0.0",
        "vite": "^5.4.7",
        "vite-electron-plugin": "^0.8.3",
        "vite-plugin-electron": "^0.28.8",
        "vite-plugin-electron-renderer": "^0.14.6",
        "vite-plugin-esmodule": "^1.5.0",
        "vitest": "^2.1.1",
        "vue": "^3.5.7",
        "vue-router": "^4.4.5",
        "vue-tsc": "^2.1.6",
        "worker-plugin": "^5.0.1"
    },
    "overrides": {
        "eslint": "$eslint",
        "@typescript-eslint/eslint-plugin": "$@typescript-eslint/eslint-plugin",
        "eslint-plugin-unused-imports": "$eslint-plugin-unused-imports"
    }
}
