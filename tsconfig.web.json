{
    "extends": "./tsconfig.common.json",
    "include": [
        "src/renderer/**/*",
        "src/common/**/*",
        "src/typed-router.d.ts"
    ],
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/renderer/*"
            ],
            "$/*": [
                "src/common/*"
            ],
        },
        "moduleResolution": "Bundler",
        "types": [
            "unplugin-vue-router/client"
        ]
    }
}