{
    "compilerOptions": {
        "target": "ESNext",
        "module": "esnext",
        "types": ["vite/client"],
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "baseUrl": ".",
        "outDir": "dist",
        "moduleResolution": "node",
        "resolveJsonModule": true
    }
}
